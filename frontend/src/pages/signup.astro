---
import "../styles/global.css";
const title = "Klinik Sehat | Daftar Akun";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
        />
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Iosevka+Charon:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap"
            rel="stylesheet"
        />
    </head>

    <body class="bg-body-secondary min-vh-100 d-flex align-items-center">
        <div class="container font-iosevka">
            <div class="row justify-content-center">
                <div class="col-11 col-sm-8 col-lg-6 col-xl-5">
                    <div class="card border-1 rounded-4 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="text-uppercase text-center mb-1">
                                Create an account
                            </h5>
                            <small
                                class="d-block text-center text-muted mt-1 mb-3"
                                >Sebelum membuat antrean, silakan buat akun
                                terlebih dahulu.</small
                            >
                            <form>
                                <div class="form-outline mt-2 mb-3">
                                    <label class="form-label" for=""
                                        >Nama Lengkap</label
                                    >
                                    <input
                                        type="text"
                                        id=""
                                        class="form-control form-control-sm bg-body-secondary"
                                    />
                                </div>
                                <div class="form-outline mb-3">
                                    <label class="form-label" for=""
                                        >Email</label
                                    >
                                    <input
                                        type="email"
                                        id=""
                                        class="form-control form-control-sm bg-body-secondary"
                                    />
                                </div>
                                <div class="form-outline mb-3">
                                    <label class="form-label" for=""
                                        >Password</label
                                    >
                                    <input
                                        type="password"
                                        id=""
                                        class="form-control form-control-sm bg-body-secondary"
                                    />
                                </div>

                                <div class="form-outline mb-3">
                                    <label class="form-label" for=""
                                        >Repeat your password</label
                                    >
                                    <input
                                        type="password"
                                        id=""
                                        class="form-control form-control-sm bg-body-secondary"
                                    />
                                </div>

                                <div
                                    class="form-check d-flex justify-content-center mb-2"
                                >
                                    <input
                                        class="form-check-input me-2 bg-body-secondary dark"
                                        type="checkbox"
                                        value=""
                                        id=""
                                    />
                                    <label class="form-check-label" for="">
                                        I agree all statements in <a
                                            href="#!"
                                            class="text-body"
                                            ><u>Terms of service</u></a
                                        >
                                    </label>
                                </div>

                                <div class="d-flex justify-content-center">
                                    <a href="reservation.html">
                                        <button
                                            type="button"
                                            class="btn btn-success btn-block btn-md text-white"
                                            >Register</button
                                        >
                                    </a>
                                </div>

                                <p class="text-center text-muted mt-5 mb-0">
                                    Have already an account? <a
                                        href="../index.html"
                                        class="fw-bold text-body"
                                        ><u>Login here</u></a>
                                </p>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <script
            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
    </body>
</html>
