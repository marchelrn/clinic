---
import Layout from "../layouts/layouts.astro";
const title = "Klinik Sehat | Jadwal Dokter";
---

<Layout title={title}>
    <header>
        <nav class="navbar navbar-expand-lg bg-white">
            <div class="container-fluid text-center font-iosevka">
                <a class="navbar-brand mx-5 text-dark" href="#">
                    <strong>Klinik Sehat</strong></a
                >
                <button
                    class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarSupportedContent"
                    aria-controls="navbarSupportedContent"
                    aria-expanded="false"
                    aria-label="Toggle navigation"
                >
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div
                    class="collapse navbar-collapse align-items-center"
                    id="navbarSupportedContent"
                >
                    <ul class="navbar-nav mx-auto gap-3 mb-2 mb-lg-0 gx-5">
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/">Beranda</a>
                        </li>
                        <li class="nav-item">
                            <a
                                class="nav-link active text-dark fw-bold"
                                href="/schedule">Jadwal Dokter</a
                            >
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/reservation"
                                >Reservasi</a
                            >
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/queue"
                                >Antrean</a
                            >
                        </li>
                        <li class="nav-item d-lg-none">
                            <!-- If display Large this list would be hidden  -->
                            <a class="nav-link text-dark" href="/signup">
                                <img
                                    src="https://ui-avatars.com/api/?rounded=true&name=Minda+Musuma&background=000&color=ffff&size=100"
                                    width="35"
                                    height="35"
                                    class="img-fluid me-2"
                                />
                                Minda Musuma
                            </a>
                        </li>
                    </ul>
                    <a href="/signup" class="d-none d-lg-block">
                        <!-- if display under large this picture would be active-->
                        <picture class="mx-5">
                            <source
                                srcset="https://ui-avatars.com/api/?rounded=true&name=Minda+Musuma&background=000&color=ffff&size=100"
                                type="image/png"
                            />
                            <img
                                src="https://ui-avatars.com/api/?rounded=true&name=Minda+Musuma&background=0000&color=ffff&size=100"
                                width="35"
                                height="35"
                                class="img-fluid"
                            />
                        </picture>
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mx-auto mt-4 font-iosevka">
        <div class="mb-4">
            <h2 class="fw-bold">Jadwal Dokter</h2>
            <p class="text-muted">
                Lihat jadwal praktek dokter dan buat janji temu
            </p>
        </div>

        <div class="card p-4 mb-5">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small fw-bold">Spesialisasi</label>
                    <select class="form-select">
                        <option selected>Semua Spesialisasi</option>
                        <option>Poli Umum</option>
                        <option>Poli Anak</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold">Hari</label>
                    <select class="form-select">
                        <option selected>Semua Hari</option>
                        <option>Senin - Rabu</option>
                        <option>Kamis - Sabtu</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold">Waktu</label>
                    <select class="form-select">
                        <option selected>Semua Waktu</option>
                        <option>Pagi</option>
                        <option>Sore</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card p-4 h-100 shadow-sm">
                    <div class="mb-3">
                        <h4 class="fw-bold mb-1">Dr. Ahmad Wijaya</h4>
                        <p class="text-primary mb-2">Dokter Umum</p>
                        <div class="text-warning small">
                            <i class="bi bi-star-fill"></i> 4.8
                        </div>
                    </div>

                    <hr class="text-light-emphasis" />

                    <div class="mb-4">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-calendar3 me-3 text-secondary"></i>
                            <div>
                                <span class="d-block fw-bold">Senin - Rabu</span
                                >
                                <small class="text-muted">08:00 - 12:00</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="bi bi-geo-alt me-3 text-secondary"></i>
                            <span>Ruang 101</span>
                        </div>
                    </div>
                    <a
                        href="signup.html"
                        class="text-white text-decoration-none"
                    >
                        <button class="btn btn-primary w-100 mt-auto fw-bold"
                            >Buat Janji Temu</button
                        >
                    </a>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card p-4 h-100 shadow-sm">
                    <div class="mb-3">
                        <h4 class="fw-bold mb-1">Dr. Siti Nurhaliza, Sp.A</h4>
                        <p class="text-primary mb-2">Spesialis Anak</p>
                        <div class="text-warning small">
                            <i class="bi bi-star-fill"></i> 4.9
                        </div>
                    </div>

                    <hr class="text-light-emphasis" />

                    <div class="mb-4">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-calendar3 me-3 text-secondary"></i>
                            <div>
                                <span class="d-block fw-bold"
                                    >Selasa - Kamis</span
                                >
                                <small class="text-muted">09:00 - 13:00</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="bi bi-geo-alt me-3 text-secondary"></i>
                            <span>Ruang 102</span>
                        </div>
                    </div>
                    <a
                        href="signup.html"
                        class="text-white text-decoration-none"
                    >
                        <button class="btn btn-primary w-100 mt-auto fw-bold"
                            >Buat Janji Temu</button
                        >
                    </a>
                </div>
            </div>
        </div>
    </div>
</Layout>
